# AI provider to use: "ollama" (local) or "openai"
AI_PROVIDER=ollama

# Ollama settings (used when AI_PROVIDER=ollama)
# Run: ollama pull llama3.2 to download the model
OLLAMA_MODEL=llama3.2

# OpenAI settings (used when AI_PROVIDER=openai)
# Get your API key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
